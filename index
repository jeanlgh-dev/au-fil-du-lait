<!DOCTYPE html>
<html lang="fr" id="html-root">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Glacerie d'Arlon — Artisans Glaciers depuis 1962</title>
<meta name="description" content="Glaces artisanales à Arlon depuis 1962. 8 parfums uniques, ingrédients naturels, trois générations de passion."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
<style>
/* ═══════════════════════════════════════
   VARIABLES & RESET
═══════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:      #c41e3a;
  --red-dark: #9e1630;
  --red-light:#f5e6ea;
  --white:    #ffffff;
  --offwhite: #f8f5f0;
  --grey-l:   #f0ece6;
  --grey:     #c8c0b8;
  --dark:     #1a1612;
  --text:     #2a2018;
  --muted:    #8a7f74;
  --radius:   0px;
  --font-d:   'Playfair Display', Georgia, serif;
  --font-b:   'Jost', system-ui, sans-serif;
  --nav-h:    72px;
  --menu-w:   460px;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--font-b);background:var(--offwhite);color:var(--text);
  overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}
button{cursor:pointer;background:none;border:none;font-family:var(--font-b)}

/* ═══════════════════════════════════════
   NAV
═══════════════════════════════════════ */
#navbar{
  position:fixed;top:0;left:0;right:0;z-index:800;
  height:var(--nav-h);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 3rem;
  transition:background .35s,box-shadow .35s;
}
#navbar.scrolled{
  background:rgba(248,245,240,.95);
  backdrop-filter:blur(16px);
  box-shadow:0 1px 0 rgba(0,0,0,.08);
}
.nav-burger{
  display:flex;flex-direction:column;gap:6px;padding:8px;
  transition:opacity .2s;
}
.nav-burger span{display:block;width:24px;height:1.5px;background:var(--white);
  transition:background .3s,transform .3s}
#navbar.scrolled .nav-burger span{background:var(--dark)}
.nav-burger:hover{opacity:.7}
.nav-logo{
  font-family:var(--font-d);font-size:1.6rem;font-weight:700;
  color:var(--white);letter-spacing:.06em;text-transform:uppercase;
  transition:color .3s;
}
#navbar.scrolled .nav-logo{color:var(--red)}
.nav-logo small{display:block;font-size:.55rem;font-weight:400;
  letter-spacing:.2em;font-family:var(--font-b);margin-top:-.2rem;
  font-style:italic;color:rgba(255,255,255,.7);transition:color .3s}
#navbar.scrolled .nav-logo small{color:var(--muted)}
.nav-lang{
  font-size:.72rem;font-weight:500;letter-spacing:.18em;
  text-transform:uppercase;color:rgba(255,255,255,.75);
  padding:.4rem .8rem;border:1px solid rgba(255,255,255,.3);
  border-radius:2px;transition:all .25s;
}
#navbar.scrolled .nav-lang{color:var(--muted);border-color:var(--grey)}
.nav-lang:hover{background:var(--red);color:var(--white);border-color:var(--red)}

/* ═══════════════════════════════════════
   MENU LATÉRAL (style Bachir)
═══════════════════════════════════════ */
#menu-overlay{
  position:fixed;inset:0;z-index:1000;
  pointer-events:none;
}
#menu-overlay.open{pointer-events:all}

.menu-backdrop{
  position:absolute;inset:0;
  background:rgba(26,22,18,.5);
  opacity:0;transition:opacity .4s ease;
}
#menu-overlay.open .menu-backdrop{opacity:1}

.menu-panel{
  position:absolute;top:0;left:0;bottom:0;
  width:var(--menu-w);
  background:var(--white);
  transform:translateX(-100%);
  transition:transform .5s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;
  padding:3rem 3rem 2.5rem;
  overflow-y:auto;
}
#menu-overlay.open .menu-panel{transform:translateX(0)}

.menu-close{
  position:absolute;top:2rem;right:2rem;
  font-size:1.4rem;color:var(--muted);
  padding:.5rem;transition:color .2s;
}
.menu-close:hover{color:var(--red)}

.menu-logo{
  font-family:var(--font-d);font-size:1.5rem;font-weight:700;
  color:var(--red);letter-spacing:.06em;text-transform:uppercase;
  margin-bottom:.2rem;
}
.menu-logo small{display:block;font-size:.55rem;font-weight:400;
  letter-spacing:.18em;font-family:var(--font-b);color:var(--muted);font-style:italic}

.menu-divider{width:40px;height:2px;background:var(--red);margin:1.8rem 0}

.menu-nav{display:flex;flex-direction:column;gap:0;flex:1}
.menu-link{
  display:flex;align-items:center;justify-content:space-between;
  font-family:var(--font-d);font-size:1.45rem;font-weight:400;
  color:var(--dark);padding:1rem 0;
  border-bottom:1px solid var(--grey-l);
  transition:color .2s;cursor:pointer;
}
.menu-link:last-child{border-bottom:none}
.menu-link:hover{color:var(--red)}
.menu-link .arrow{font-size:1rem;color:var(--grey);transition:transform .2s,color .2s}
.menu-link:hover .arrow{transform:translateX(4px);color:var(--red)}

.menu-foot{margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--grey-l)}
.menu-foot-label{font-size:.65rem;font-weight:500;letter-spacing:.2em;
  text-transform:uppercase;color:var(--muted);margin-bottom:.8rem}
.menu-lang-btns{display:flex;gap:1rem}
.menu-lang-btn{
  font-size:.85rem;font-weight:400;letter-spacing:.06em;
  color:var(--muted);padding:.3rem 0;
  border-bottom:1px solid transparent;transition:all .2s;background:none;border:none;
  font-family:var(--font-b);cursor:pointer;
}
.menu-lang-btn.active{color:var(--red);border-bottom-color:var(--red)}
.menu-lang-btn:hover{color:var(--red)}
.lang-sep{color:var(--grey);align-self:center;font-size:.8rem}

/* ═══════════════════════════════════════
   PAGES OVERLAY (Histoire, Horaires, etc.)
═══════════════════════════════════════ */
.page-overlay{
  position:fixed;inset:0;z-index:900;
  background:var(--offwhite);
  transform:translateX(100%);
  transition:transform .55s cubic-bezier(.4,0,.2,1);
  overflow-y:auto;
}
.page-overlay.open{transform:translateX(0)}

.page-inner{
  max-width:800px;margin:0 auto;
  padding:8rem 3rem 5rem;
}
.page-back{
  display:inline-flex;align-items:center;gap:.6rem;
  font-size:.75rem;font-weight:500;letter-spacing:.15em;
  text-transform:uppercase;color:var(--muted);
  margin-bottom:3rem;cursor:pointer;transition:color .2s;background:none;border:none;
  font-family:var(--font-b);
}
.page-back:hover{color:var(--red)}
.page-back::before{content:'←';font-size:1rem}
.page-title{
  font-family:var(--font-d);font-size:clamp(2.5rem,5vw,4rem);
  font-weight:400;color:var(--dark);margin-bottom:2.5rem;line-height:1.1;
}
.page-title em{font-style:italic;color:var(--red)}
.page-body{font-size:1rem;font-weight:300;color:var(--muted);line-height:1.9}
.page-body p+p{margin-top:1.2rem}
.page-body h3{
  font-family:var(--font-d);font-size:1.5rem;font-weight:400;
  color:var(--dark);margin:2.5rem 0 .8rem;
}
.page-body strong{color:var(--red);font-weight:500}

/* Horaires table */
.horaires-table{width:100%;border-collapse:collapse;margin-top:1.5rem}
.horaires-table tr{border-bottom:1px solid var(--grey-l)}
.horaires-table td{padding:1rem .5rem;font-size:.95rem;font-weight:300;color:var(--muted)}
.horaires-table td:first-child{font-weight:500;color:var(--dark);width:45%}
.horaires-table tr.closed td{color:var(--grey)}

/* Recrutement */
.recru-block{
  background:var(--white);border:1px solid var(--grey-l);
  padding:2rem;margin-top:2rem;
}
.recru-block h4{font-family:var(--font-d);font-size:1.3rem;font-weight:400;
  color:var(--dark);margin-bottom:.5rem}
.recru-block p{font-size:.9rem;font-weight:300;color:var(--muted);line-height:1.7}
.recru-block .btn-red{margin-top:1.2rem}

/* Contact form */
.cform{display:flex;flex-direction:column;gap:1.2rem;margin-top:2rem}
.cform input,.cform textarea,.cform select{
  width:100%;padding:1rem;
  border:1px solid var(--grey-l);background:var(--white);
  font-family:var(--font-b);font-size:.95rem;font-weight:300;color:var(--dark);
  outline:none;transition:border-color .2s;
}
.cform input:focus,.cform textarea:focus{border-color:var(--red)}
.cform textarea{min-height:120px;resize:vertical}

/* Univers gallery */
.univ-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:2rem}
.univ-grid img{width:100%;aspect-ratio:4/3;object-fit:cover}
.univ-grid .full{grid-column:span 2;aspect-ratio:16/7}

/* ═══════════════════════════════════════
   BUTTONS
═══════════════════════════════════════ */
.btn-red{
  display:inline-block;background:var(--red);color:var(--white);
  font-size:.8rem;font-weight:500;letter-spacing:.14em;text-transform:uppercase;
  padding:1rem 2.4rem;border:2px solid var(--red);
  transition:background .25s,color .25s,transform .2s;
  font-family:var(--font-b);cursor:pointer;
}
.btn-red:hover{background:transparent;color:var(--red);transform:translateY(-2px)}
.btn-outline{
  display:inline-block;background:transparent;color:var(--white);
  font-size:.8rem;font-weight:500;letter-spacing:.14em;text-transform:uppercase;
  padding:1rem 2.4rem;border:2px solid rgba(255,255,255,.6);
  transition:all .25s;font-family:var(--font-b);cursor:pointer;
}
.btn-outline:hover{border-color:var(--white);background:var(--white);color:var(--red)}

/* ═══════════════════════════════════════
   HERO
═══════════════════════════════════════ */
.hero{
  position:relative;height:100vh;min-height:640px;
  display:flex;align-items:center;overflow:hidden;
}
.hero-photo{
  position:absolute;inset:0;z-index:0;
  background:
    linear-gradient(to right,rgba(26,22,18,.72) 38%,rgba(26,22,18,.2) 100%),
    url('https://images.unsplash.com/photo-1501443762994-82bd5dace89a?w=1800&q=85&fit=crop') center/cover no-repeat;
  will-change:transform;
  transition:transform .1s linear;
}
.hero-content{
  position:relative;z-index:2;
  padding:0 5rem;max-width:680px;
}
.hero-eyebrow{
  font-size:.72rem;font-weight:500;letter-spacing:.28em;text-transform:uppercase;
  color:var(--red);margin-bottom:1.5rem;
  display:flex;align-items:center;gap:.8rem;
}
.hero-eyebrow::before{content:'';display:block;width:32px;height:1.5px;background:var(--red)}
.hero-title{
  font-family:var(--font-d);
  font-size:clamp(3rem,6.5vw,6rem);
  font-weight:700;line-height:.95;text-transform:uppercase;
  color:var(--white);margin-bottom:1.8rem;letter-spacing:.02em;
}
.hero-title em{display:block;font-style:italic;font-weight:400;
  font-size:.65em;letter-spacing:.04em;color:rgba(255,255,255,.85)}
.hero-sub{
  font-size:1rem;font-weight:300;color:rgba(255,255,255,.7);
  line-height:1.75;margin-bottom:2.8rem;
}
.hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
.hero-scroll{
  position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
  z-index:2;display:flex;flex-direction:column;align-items:center;gap:.6rem;
}
.hero-scroll span{font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;
  color:rgba(255,255,255,.4)}
.scroll-line{width:1px;height:44px;
  background:linear-gradient(to bottom,var(--red),transparent);
  animation:sline 1.8s ease-in-out infinite}
@keyframes sline{0%{opacity:1;transform:scaleY(1) translateY(0)}
  100%{opacity:0;transform:scaleY(.3) translateY(18px)}}

/* ═══════════════════════════════════════
   STRIP CHIFFRES
═══════════════════════════════════════ */
.strip{background:var(--red);padding:0}
.strip-grid{display:grid;grid-template-columns:repeat(4,1fr)}
.strip-item{
  padding:3.5rem 2rem;text-align:center;
  border-right:1px solid rgba(255,255,255,.15);
}
.strip-item:last-child{border-right:none}
.strip-num{
  font-family:var(--font-d);font-size:3.5rem;font-weight:700;
  color:var(--white);display:block;line-height:1;
}
.strip-label{
  font-size:.68rem;font-weight:400;letter-spacing:.16em;
  text-transform:uppercase;color:rgba(255,255,255,.6);
  margin-top:.5rem;display:block;
}

/* ═══════════════════════════════════════
   HISTOIRE (accueil snippet)
═══════════════════════════════════════ */
.histoire-snap{padding:8rem 0;background:var(--white)}
.histoire-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:7rem;
  align-items:center;max-width:1180px;margin:0 auto;padding:0 4rem;
}
.histoire-img{position:relative}
.histoire-img-main{
  width:100%;aspect-ratio:4/5;object-fit:cover;
}
.histoire-img-badge{
  position:absolute;bottom:-1.5rem;right:-1.5rem;
  width:110px;height:110px;background:var(--red);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  color:var(--white);
}
.histoire-img-badge span:first-child{
  font-family:var(--font-d);font-size:2rem;font-weight:700;line-height:1;
}
.histoire-img-badge span:last-child{
  font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;margin-top:.2rem;
}
.histoire-text .s-eyebrow{
  font-size:.68rem;font-weight:500;letter-spacing:.24em;text-transform:uppercase;
  color:var(--red);margin-bottom:1rem;
  display:flex;align-items:center;gap:.7rem;
}
.histoire-text .s-eyebrow::before{content:'';width:24px;height:1.5px;background:var(--red)}
.histoire-text h2{
  font-family:var(--font-d);font-size:clamp(2rem,3.5vw,3rem);
  font-weight:400;color:var(--dark);line-height:1.15;margin-bottom:1.8rem;
}
.histoire-text h2 em{font-style:italic;color:var(--red)}
.histoire-text p{font-size:.97rem;font-weight:300;color:var(--muted);line-height:1.9;margin-bottom:1rem}
.histoire-text .sign{
  font-family:var(--font-d);font-size:2rem;font-style:italic;
  color:var(--red);margin-top:1.5rem;display:block;
}
.histoire-link{
  display:inline-flex;align-items:center;gap:.5rem;margin-top:1.8rem;
  font-size:.75rem;font-weight:500;letter-spacing:.16em;text-transform:uppercase;
  color:var(--red);border-bottom:1px solid var(--red);padding-bottom:.2rem;
  cursor:pointer;transition:gap .2s;background:none;border-top:none;border-left:none;border-right:none;
  font-family:var(--font-b);
}
.histoire-link:hover{gap:.9rem}
.histoire-link::after{content:'→'}

/* ═══════════════════════════════════════
   SECTION TROPICAL MOODBOARD
═══════════════════════════════════════ */
.tropical-section{
  height:280vh;position:relative;
}
.tropical-sticky{
  position:sticky;top:0;height:100vh;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  /* fond dégradé pastel tropical */
  background:linear-gradient(135deg,#fff9f0 0%,#fff0e8 30%,#fde8f5 60%,#e8f5fd 100%);
}
/* grain texture sur le fond */
.tropical-sticky::before{
  content:'';position:absolute;inset:0;pointer-events:none;z-index:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity:.6;
}
.tropical-stage{
  position:relative;width:100%;max-width:1200px;
  height:100vh;margin:0 auto;
  overflow:hidden;
}
/* Titre central */
.trop-title{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  text-align:center;z-index:2;pointer-events:none;
  opacity:0;transition:opacity .6s;
}
.trop-title.vis{opacity:1}
.trop-title h2{
  font-family:var(--font-d);font-size:clamp(2.5rem,5vw,5rem);
  font-weight:700;color:var(--dark);text-transform:uppercase;
  letter-spacing:.04em;line-height:1;
}
.trop-title h2 em{font-style:italic;color:var(--red);font-weight:400}
.trop-title p{
  margin-top:.8rem;font-size:.78rem;font-weight:400;
  letter-spacing:.22em;text-transform:uppercase;color:var(--muted);
}
/* Éléments cutout — positionnés absolument, animés au scroll */
.trop-el{
  position:absolute;will-change:transform;z-index:3;
  transition:none;
  filter:drop-shadow(0 8px 20px rgba(0,0,0,.12));
}
/* Chaque élément part d'une position hors-écran définie en JS */
#tSun   { width:clamp(100px,14vw,200px); top:8%;  left:50%; transform:translateX(-50%) translateY(-120vh); }
#tPalm  { width:clamp(80px,10vw,150px);  top:5%;  left:4%;  transform:translateX(-60vw); }
#tPalm2 { width:clamp(80px,10vw,150px);  top:5%;  right:4%; transform:translateX(60vw);  transform-origin:top right; }
#tTrans { width:clamp(90px,12vw,170px);  bottom:12%; left:8%;  transform:translateX(-60vw); }
#tParas { width:clamp(90px,12vw,160px);  bottom:10%; right:10%; transform:translateX(60vw); }
#tCockt { width:clamp(70px,9vw,130px);   top:22%; right:6%;  transform:translateX(60vw); }
#tBouee { width:clamp(80px,11vw,150px);  top:18%; left:6%;   transform:translateX(-60vw); }
#tWave  { width:100%; bottom:0; left:0;  transform:translateY(100%); z-index:1; opacity:.5; }

/* ═══════════════════════════════════════
   PARFUMS
═══════════════════════════════════════ */
.parfums{padding:8rem 0;background:var(--white)}
.sec-header{
  max-width:1180px;margin:0 auto;padding:0 4rem;
  display:grid;grid-template-columns:1fr 1fr;gap:4rem;
  align-items:end;margin-bottom:4rem;
}
.sec-eyebrow{
  font-size:.68rem;font-weight:500;letter-spacing:.24em;text-transform:uppercase;
  color:var(--red);margin-bottom:1rem;
  display:flex;align-items:center;gap:.7rem;
}
.sec-eyebrow::before{content:'';width:24px;height:1.5px;background:var(--red)}
.sec-title{
  font-family:var(--font-d);font-size:clamp(2rem,3.5vw,3rem);
  font-weight:400;color:var(--dark);line-height:1.15;
}
.sec-title em{font-style:italic;color:var(--red)}
.sec-sub{font-size:.95rem;font-weight:300;color:var(--muted);line-height:1.8}

.parfums-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  max-width:1180px;margin:0 auto;padding:0 4rem;
  gap:1px;background:var(--grey-l);
}
.pcard{
  background:var(--white);
  transition:background .3s;cursor:pointer;
}
.pcard:hover{background:var(--offwhite)}
.pcard-img{width:100%;aspect-ratio:3/4;overflow:hidden}
.pcard-img img{width:100%;height:100%;object-fit:cover;
  transition:transform .6s ease;display:block}
.pcard:hover .pcard-img img{transform:scale(1.06)}
.pcard-body{padding:1.4rem 1.2rem 1.8rem}
.pcard-num{font-size:.62rem;font-weight:500;letter-spacing:.18em;
  color:var(--red);text-transform:uppercase;margin-bottom:.4rem}
.pcard-name{font-family:var(--font-d);font-size:1.15rem;font-weight:400;
  color:var(--dark);margin-bottom:.4rem}
.pcard-desc{font-size:.78rem;font-weight:300;color:var(--muted);
  line-height:1.65;margin-bottom:.9rem}
.pcard-price{font-family:var(--font-d);font-size:1.3rem;font-weight:400;color:var(--red)}
.pcard-price span{font-size:.7rem;color:var(--muted);font-family:var(--font-b)}

/* Ligne 2 de parfums */
.parfums-grid-2{
  display:grid;grid-template-columns:repeat(4,1fr);
  max-width:1180px;margin:1px auto 0;padding:0 4rem;
  gap:1px;background:var(--grey-l);
}

/* ═══════════════════════════════════════
   MARQUEE
═══════════════════════════════════════ */
.marquee{padding:2rem 0;background:var(--red);overflow:hidden;white-space:nowrap}
.marquee-inner{display:inline-block;animation:mq 20s linear infinite}
.marquee-inner span{
  font-family:var(--font-d);font-size:1.4rem;font-weight:400;font-style:italic;
  color:rgba(255,255,255,.9);padding:0 2rem;
}
.marquee-inner span::before{content:'✦';margin-right:2rem;font-style:normal;font-size:.9rem}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ═══════════════════════════════════════
   ENGAGEMENTS
═══════════════════════════════════════ */
.engagements{padding:8rem 0;background:var(--offwhite)}
.eng-wrap{max-width:1180px;margin:0 auto;padding:0 4rem}
