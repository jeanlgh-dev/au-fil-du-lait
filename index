<script>
'use strict';

/* ── NAV SCROLL ── */
const nav = document.getElementById('navbar');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
}, { passive: true });

/* ── MENU ── */
const menuOverlay = document.getElementById('menu-overlay');
function openMenu() { menuOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeMenu() { menuOverlay.classList.remove('open'); document.body.style.overflow = ''; }
function scrollToMain() { window.scrollTo({ top: 0, behavior: 'smooth' }); }

/* ── PAGES ── */
let openPages = [];
function openPage(id) {
  closeMenu();
  setTimeout(() => {
    const el = document.getElementById(id);
    if (el) { el.classList.add('open'); openPages.push(id); document.body.style.overflow = 'hidden'; }
  }, 300);
}
function closePage(id) {
  const el = document.getElementById(id);
  if (el) { el.classList.remove('open'); openPages = openPages.filter(p => p !== id); }
  if (openPages.length === 0) document.body.style.overflow = '';
}
// Close pages with Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (openPages.length > 0) { closePage(openPages[openPages.length - 1]); }
    else closeMenu();
  }
});

/* ── LANGUE ── */
let lang = 'fr';
function setLang(l) {
  lang = l;
  document.getElementById('langBtn').textContent = l === 'fr' ? 'EN' : 'FR';
  document.getElementById('btnFr').classList.toggle('active', l === 'fr');
  document.getElementById('btnEn').classList.toggle('active', l === 'en');
  document.querySelectorAll('[data-fr]').forEach(el => {
    const txt = el.getAttribute('data-' + l);
    if (txt) el.innerHTML = txt;
  });
}
function toggleLang() { setLang(lang === 'fr' ? 'en' : 'fr'); }

/* ── REVEAL ── */
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.rv,.rv-l,.rv-r,.rv-sc').forEach(el => obs.observe(el));

/* ── PARALLAX HERO ── */
const heroPar = document.getElementById('heroPar');
const heroEl = document.querySelector('.hero');
window.addEventListener('scroll', () => {
  if (window.scrollY < heroEl.offsetHeight * 1.4 && heroPar)
    heroPar.style.transform = 'translateY(' + window.scrollY * 0.28 + 'px) scale(1.02)';
}, { passive: true });

/* ── TROPICAL MOODBOARD SCROLL ── */
const tropSection = document.getElementById('tropSection');
const tropTitle   = document.getElementById('tropTitle');
const tropEls = [
  { el: document.getElementById('tSun'),   fx: 0,    fy: -1.1 },
  { el: document.getElementById('tPalm'),  fx: -1.1, fy: 0    },
  { el: document.getElementById('tPalm2'), fx: 1.1,  fy: 0    },
  { el: document.getElementById('tTrans'), fx: -1.1, fy: 0    },
  { el: document.getElementById('tParas'), fx: 1.1,  fy: 0    },
  { el: document.getElementById('tCockt'), fx: 1.1,  fy: 0    },
  { el: document.getElementById('tBouee'), fx: -1.1, fy: 0    },
  { el: document.getElementById('tWave'),  fx: 0,    fy: 1    },
];
function easeOutCubic(t){ return 1 - Math.pow(1-t,3); }

window.addEventListener('scroll', () => {
  if (!tropSection) return;
  const rect = tropSection.getBoundingClientRect();
  const sH = tropSection.offsetHeight;
  const vH = window.innerHeight;
  const prog = Math.max(0, Math.min(1, -rect.top / (sH - vH)));
  const arriveP = easeOutCubic(Math.min(1, prog / 0.5));
  const titleP  = Math.max(0, Math.min(1, (prog - 0.4) / 0.25));

  tropEls.forEach(({ el, fx, fy }) => {
    if (!el) return;
    el.style.transform = 'translate(' + (fx*(1-arriveP)*100) + 'vw,' + (fy*(1-arriveP)*100) + 'vh)';
    el.style.opacity = String(arriveP);
  });

  if (tropTitle) {
    tropTitle.style.opacity = String(titleP);
    tropTitle.style.transform = 'translate(-50%,calc(-50% + ' + ((1-titleP)*20) + 'px))';
    tropTitle.classList.toggle('vis', titleP > 0.05);
  }
}, { passive: true });

/* ── SMOOTH SCROLL ── */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const t = document.querySelector(a.getAttribute('href'));
    if (!t) return; e.preventDefault();
    window.scrollTo({ top: t.getBoundingClientRect().top + window.scrollY - 72, behavior: 'smooth' });
  });
});

/* ── HERO FADE IN ── */
document.querySelectorAll('.hero-content > *').forEach((el, i) => {
  el.style.cssText = 'opacity:0;transform:translateY(24px);transition:opacity .8s ease,transform .8s ease;transition-delay:' + (i * 160 + 200) + 'ms';
  setTimeout(() => { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }, 50);
});

/* ── FORM ── */
function handleForm(e) {
  e.preventDefault();
  alert('Merci pour votre message !\nNous vous répondrons sous 48h par email.');
  e.target.reset();
}
</script>
